  "keyFeatures": [
    "LSM-tree storage engine built on object storage (S3, GCS, ABS, MinIO)",
    "Bottomless storage capacity with high durability and easy replication",
    "ACID transactions with configurable isolation levels",
    "Efficient range queries and prefix scanning with seek support",
    "Compression support (Snappy, Zlib, LZ4, Zstd)",
    "Block cache, disk cache, and bloom filters for performance",
    "Automatic compaction with configurable strategies",
    "Merge operators for atomic read-modify-write operations",
    "Snapshots and checkpoints for consistent point-in-time reads",
    "Change data capture (CDC) for streaming database changes",
    "Language bindings for Rust, Go, Java, Python, and more"
  ],
  "publicApiSurface": [
    "Db::open() - Open or create a database",
    "Db::put() - Write a key-value pair",
    "Db::get() - Read a value by key",
    "Db::delete() - Delete a key",
    "Db::scan() - Iterate over a range of keys",
    "Db::scan_prefix() - Iterate over keys with a common prefix",
    "Db::merge() - Apply a merge operation",
    "Db::write() - Write a batch of operations",
    "Db::begin() - Start a transaction",
    "Db::snapshot() - Create a point-in-time snapshot",
    "Db::flush() - Flush memtable to object storage",
    "Db::close() - Close the database",
    "DbBuilder - Configure and build a database instance",
    "DbTransaction - Execute ACID transactions",
    "DbSnapshot - Read from a consistent point-in-time view",
    "DbIterator - Iterate over key-value pairs",
    "WriteBatch - Batch multiple write operations",
    "Settings - Configure database behavior",
    "CompactorBuilder - Configure background compaction",
    "GarbageCollectorBuilder - Configure garbage collection",
    "MergeOperator - Define custom merge logic",
    "Checkpoint - Create and restore checkpoints"
  ]
}
